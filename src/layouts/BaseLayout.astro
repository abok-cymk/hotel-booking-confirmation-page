---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Maison Soleil - Your stay",
  description = "Your confirmed booking at Maison Soleil, a sun-washed guesthouse in the hills above Cassis.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="--bg-background">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6ede0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="--min-h-dvh">
    <slot />
  </body>
</html>
